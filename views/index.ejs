<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CineScope</title>
  <link rel="stylesheet" href="style.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
</head>

<body>

<h1>🎬 CineScope</h1>
<p class="subtitle">
Discover movies instantly with real-time data from the OMDb API.
</p>

<br><br>

<div class="row mb-1">
<form action="/" method="post">
<div class="col-8 offset-2 formDiv">

<label class="form-label searchHeading">Search</label>

<input name="apikey" type="hidden" value="2104fc3e">

<input
name="t"
id="title"
required
class="w-75 p-2 rounded"
type="text"
placeholder="Search by Movie Title"
/>

<button type="submit">
<i class="fa-solid fa-magnifying-glass"></i>
</button>

</div>
</form>
</div>

<br>

<div style="text-align:center;margin:20px;">
<button id="showFavs" class="favorite-btn">❤️ View Favorites</button>
</div>

<div id="favoritesList"></div>

<% if(!movie || Object.keys(movie).length===0){ %>

<div class="welcome-card">
<h2>Welcome to CineScope 🎬</h2>
<p>
Search over thousands of movies instantly using real-time data from the OMDb API.
Discover ratings, cast, genres, release dates and much more.
</p>
</div>

<% } %>

<div class="movie">

<div class="box">

<% try { %>

<% if(movie && Object.keys(movie).length>0){ %>

<div class="movie_image">

<img src="<%= movie.Image %>" alt="Movie Poster">

</div>

<div class="content">

<h2>
<a target="_blank"
href="https://www.google.com/search?q=<%= movie.title %>+movie">
<%= movie.title %> (<%= movie.Released.slice(7,11) %>)
</a>
</h2>

<div style="text-align:center;margin:20px;">
<button id="favBtn" class="favorite-btn">
❤️ Add to Favorites
</button>
</div>

<p><strong>Description:</strong> <%= movie.desc %></p>
<p><strong>Duration:</strong> <%= movie.duration %></p>
<p><strong>Genre:</strong> <%= movie.Genre %></p>
<p><strong>Director:</strong> <%= movie.Director %></p>
<p><strong>Actors:</strong> <%= movie.Actor %></p>
<p><strong>Language:</strong> <%= movie.language %></p>

<% } %>

<% } catch(err){ } %>

</div>

</div>

<footer class="footer">
<p>🎬 Powered by OMDb API | Developed by <strong>Minaksh Sharma</strong></p>
</footer>

<% if(movie && Object.keys(movie).length>0){ %>

<script>

const favBtn=document.getElementById("favBtn");

if(favBtn){

favBtn.addEventListener("click",()=>{

const movieData={
title:"<%= movie.title %>",
year:"<%= movie && movie.Released ? movie.Released.slice(7,11) : '' %>",
poster:"<%= movie.Image %>"
};

let favorites=JSON.parse(localStorage.getItem("favorites"))||[];

if(!favorites.some(m=>m.title===movieData.title)){
favorites.push(movieData);
localStorage.setItem("favorites",JSON.stringify(favorites));
alert("✅ Added to Favorites!");
}else{
alert("❤️ Already in Favorites!");
}

});

}

</script>

<% } %>

<script>

const showFavs=document.getElementById("showFavs");

showFavs.addEventListener("click",()=>{

const favorites=JSON.parse(localStorage.getItem("favorites"))||[];

let html="<div style='width:75%;margin:30px auto;background:#1E293B;padding:20px;border-radius:15px;color:white;'><h2 style='text-align:center'>❤️ Favorite Movies</h2>";

if(favorites.length===0){

html+="<p style='text-align:center'>No favorite movies yet.</p>";

}else{

favorites.forEach(movie=>{

html+=`
<div style="display:flex;gap:20px;align-items:center;background:#0f172a;padding:15px;border-radius:10px;margin:15px 0;">
<img src="${movie.poster}" width="90">
<div>
<h3>${movie.title}</h3>
<p>${movie.year}</p>
</div>
</div>`;

});

}

html+="</div>";

document.getElementById("favoritesList").innerHTML=html;

});

</script>

</body>
</html>
